"use client";

import AppShell from "@/components/AppShell";
import { supabase } from "@/lib/supabaseClient";
import Link from "next/link";
import React, { useEffect, useMemo, useState } from "react";

type Profiel = {
  id: string;
  volledige_naam: string | null;
  role: string | null;
  rol: string | null;
  klas_naam: string | null;
  schooljaar: string | null;
};

type Discipline = {
  id: string;
  slug: string;
  naam: string;
  categorie: string | null;
  eenheid: string | null;
  hoger_is_beter: boolean;
  actief: boolean;
};

type Klas = {
  id: string;
  naam: string;
  schooljaar: string;
};

type Openstelling = {
  id: string;
  discipline_id: string;
  klas_naam: string | null;
  schooljaar: string;
  open_voor_leerlingen: boolean;
};

type ScoreRow = {
  id: string;
  leerling_id: string;
  discipline_id: string;
  schooljaar: string;
  klas_naam: string | null;
  score_nummer: number | null;
  score_tekst: string | null;
  eenheid: string | null;
  status: string | null;
  bevestigd_door: string | null;
  bevestigd_op: string | null;
  aangemaakt_op: string;
  extra_data: Record<string, unknown> | null;
  leerling: {
    id: string;
    volledige_naam: string | null;
    klas_naam: string | null;
    leerjaar?: string | null;
    graad?: string | null;
    geslacht?: string | null;
  } | null;
};

type RubricRow = {
  id: string;
  discipline_id: string;
  geslacht: string | null;
  leerjaar: number | null;
  min_score: number | null;
  max_score: number | null;
  niveau: string | null;
  label: string | null;
};

const ui = {
  text: "rgba(234,240,255,0.92)",
  muted: "rgba(234,240,255,0.72)",
  panel: "rgba(255,255,255,0.06)",
  border: "rgba(255,255,255,0.12)",
  border2: "rgba(255,255,255,0.18)",
  errorBg: "rgba(255,85,112,0.15)",
  errorBorder: "rgba(255,85,112,0.28)",
};

function getRoleLabel(role?: string | null, rol?: string | null) {
  const raw = (role ?? rol ?? "").toLowerCase();
  if (raw === "teacher" || raw === "leerkracht") return "Leerkracht";
  return "Leerling";
}

function formatDateTime(value?: string | null) {
  if (!value) return "—";
  const date = new Date(value);
  return new Intl.DateTimeFormat("nl-BE", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }).format(date);
}

function formatScore(score: Pick<ScoreRow, "score_nummer" | "score_tekst" | "eenheid">) {
  if (score.score_nummer !== null && score.score_nummer !== undefined) {
    return `${score.score_nummer} ${score.eenheid ?? ""}`.trim();
  }
  if (score.score_tekst) return score.score_tekst;
  return "—";
}

function getStatusLabel(status?: string | null) {
  switch ((status ?? "").toLowerCase()) {
    case "bevestigd":
      return "Bevestigd";
    case "ingediend":
      return "Ingediend";
    case "te_herzien":
      return "Te herzien";
    case "afgekeurd":
      return "Afgekeurd";
    default:
      return "Onbekend";
  }
}

function getStatusClasses(status?: string | null) {
  switch ((status ?? "").toLowerCase()) {
    case "bevestigd":
      return "border-emerald-400/20 bg-emerald-400/10 text-emerald-200";
    case "ingediend":
      return "border-amber-300/20 bg-amber-300/10 text-amber-100";
    case "te_herzien":
      return "border-orange-300/20 bg-orange-300/10 text-orange-100";
    case "afgekeurd":
      return "border-red-400/20 bg-red-400/10 text-red-200";
    default:
      return "border-white/10 bg-white/5 text-white/70";
  }
}

function normalizeGender(value?: string | null) {
  const raw = (value ?? "").toLowerCase().trim();
  if (raw === "jongen" || raw === "man" || raw === "m") return "jongen";
  if (raw === "meisje" || raw === "vrouw" || raw === "v") return "meisje";
  return raw || null;
}

function getRubricForScore(args: {
  score: number | null;
  rubrics: RubricRow[];
  geslacht?: string | null;
  leerjaar?: string | null;
}) {
  const { score, rubrics, geslacht, leerjaar } = args;
  if (score === null || score === undefined) return null;

  const normalizedGender = normalizeGender(geslacht);
  const numericLeerjaar = leerjaar ? Number(leerjaar) : null;

  const matches = rubrics.filter((r) => {
    const genderOk =
      !r.geslacht ||
      r.geslacht.toLowerCase() === normalizedGender ||
      r.geslacht.toLowerCase() === "algemeen";

    const leerjaarOk =
      r.leerjaar === null ||
      r.leerjaar === undefined ||
      !numericLeerjaar ||
      r.leerjaar === numericLeerjaar;

    const minOk = r.min_score === null || r.min_score === undefined || score >= r.min_score;
    const maxOk = r.max_score === null || r.max_score === undefined || score < r.max_score;

    return genderOk && leerjaarOk && minOk && maxOk;
  });

  return matches[0] ?? null;
}

function getRubricClasses(niveau?: string | null) {
  switch ((niveau ?? "").trim()) {
    case "++":
      return "border-emerald-400/20 bg-emerald-400/10 text-emerald-200";
    case "+":
      return "border-yellow-300/20 bg-yellow-300/10 text-yellow-100";
    case "+/-":
      return "border-orange-300/20 bg-orange-300/10 text-orange-100";
    case "-":
      return "border-red-400/20 bg-red-400/10 text-red-200";
    default:
      return "border-white/10 bg-white/5 text-white/70";
  }
}

function TeacherScoreCard({
  row,
  rubric,
  onConfirm,
  onReview,
  onReject,
  onQuickSave,
  savingId,
}: {
  row: ScoreRow;
  rubric: RubricRow | null;
  onConfirm: (id: string) => Promise<void>;
  onReview: (id: string) => Promise<void>;
  onReject: (id: string) => Promise<void>;
  onQuickSave: (id: string, scoreNummer: string, scoreTekst: string) => Promise<void>;
  savingId: string | null;
}) {
  const [scoreNummer, setScoreNummer] = useState(
    row.score_nummer !== null && row.score_nummer !== undefined ? String(row.score_nummer) : ""
  );
  const [scoreTekst, setScoreTekst] = useState(row.score_tekst ?? "");

  return (
    <div className="rounded-[24px] border border-white/10 bg-white/5 p-4">
      <div className="flex flex-col gap-4">
        <div className="flex flex-wrap items-start justify-between gap-3">
          <div>
            <div className="text-base font-black text-white">
              {row.leerling?.volledige_naam ?? "Onbekende leerling"}
            </div>
            <div className="mt-1 text-xs text-white/55">
              {row.leerling?.klas_naam ?? row.klas_naam ?? "Geen klas"} • {formatDateTime(row.aangemaakt_op)}
            </div>
          </div>

          <span
            className={[
              "inline-flex rounded-full border px-2.5 py-1 text-[11px] font-bold",
              getStatusClasses(row.status),
            ].join(" ")}
          >
            {getStatusLabel(row.status)}
          </span>
        </div>

        <div className="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <div className="rounded-2xl border border-white/10 bg-black/20 p-3">
            <div className="text-[11px] font-black uppercase tracking-[0.08em] text-white/55">
              Score
            </div>
            <div className="mt-1 text-sm font-black text-white">{formatScore(row)}</div>
          </div>

          <div className="rounded-2xl border border-white/10 bg-black/20 p-3">
            <div className="text-[11px] font-black uppercase tracking-[0.08em] text-white/55">
              Rubric
            </div>

            {rubric ? (
              <div className="mt-1 flex items-center gap-2">
                <span
                  className={[
                    "inline-flex rounded-full border px-2.5 py-1 text-[11px] font-black",
                    getRubricClasses(rubric.niveau),
                  ].join(" ")}
                >
                  {rubric.niveau ?? "—"}
                </span>
                <span className="text-xs text-white/75">{rubric.label ?? "Resultaat"}</span>
              </div>
            ) : (
              <div className="mt-1 text-xs text-white/55">Geen rubric gevonden</div>
            )}
          </div>

          <div className="rounded-2xl border border-white/10 bg-black/20 p-3">
            <div className="text-[11px] font-black uppercase tracking-[0.08em] text-white/55">
              Leerlinggegevens
            </div>
            <div className="mt-1 text-xs text-white/75">
              Leerjaar: {row.leerling?.leerjaar ?? "—"} • Graad: {row.leerling?.graad ?? "—"}
            </div>
          </div>
        </div>

        <div className="rounded-[20px] border border-white/10 bg-black/20 p-3">
          <div className="text-sm font-black text-white">Snel aanpassen</div>

          <div className="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
            <input
              type="number"
              step="0.01"
              value={scoreNummer}
              onChange={(e) => setScoreNummer(e.target.value)}
              className="h-11 rounded-2xl border border-white/10 bg-white/5 px-4 text-sm font-semibold text-white outline-none placeholder:text-white/30"
              placeholder="Numerieke score"
            />
            <input
              type="text"
              value={scoreTekst}
              onChange={(e) => setScoreTekst(e.target.value)}
              className="h-11 rounded-2xl border border-white/10 bg-white/5 px-4 text-sm font-semibold text-white outline-none placeholder:text-white/30"
              placeholder="Tekstscore / opmerking"
            />
          </div>

          <div className="mt-3 flex flex-wrap gap-2">
            <button
              onClick={() => onQuickSave(row.id, scoreNummer, scoreTekst)}
              disabled={savingId === row.id}
              className="inline-flex h-11 items-center rounded-2xl border border-white/15 bg-black/40 px-4 text-sm font-black text-white transition hover:bg-black/55 disabled:opacity-50"
            >
              {savingId === row.id ? "Opslaan..." : "Aanpassing opslaan"}
            </button>

            <button
              onClick={() => onConfirm(row.id)}
              disabled={savingId === row.id}
              className="inline-flex h-11 items-center rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 text-sm font-black text-emerald-200 transition hover:bg-emerald-400/15 disabled:opacity-50"
            >
              Bevestigen
            </button>

            <button
              onClick={() => onReview(row.id)}
              disabled={savingId === row.id}
              className="inline-flex h-11 items-center rounded-2xl border border-orange-300/20 bg-orange-300/10 px-4 text-sm font-black text-orange-100 transition hover:bg-orange-300/15 disabled:opacity-50"
            >
              Te herzien
            </button>

            <button
              onClick={() => onReject(row.id)}
